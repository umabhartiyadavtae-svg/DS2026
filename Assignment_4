class TextEditor:
    def __init__(self):
        self.undo_stack = []
        self.redo_stack = []

    def make_change(self, change):
        self.undo_stack.append(change)
        self.redo_stack.clear()

    def undo(self):
        if self.undo_stack:
            last_change = self.undo_stack.pop()
            self.redo_stack.append(last_change)
        else:
            print("Nothing to undo.")

    def redo(self):
        if self.redo_stack:
            last_undone = self.redo_stack.pop()
            self.undo_stack.append(last_undone)
        else:
            print("Nothing to redo.")

    def display(self):
        if self.undo_stack:
            print("Current Document State:", self.undo_stack[-1])
        else:
            print("Document is empty.")

# Sample Usage
editor = TextEditor()
editor.make_change("Hello")
editor.make_change("Hello World")
editor.display()
editor.undo()
editor.display()
editor.redo()
editor.display()
editor.make_change("New Line")
editor.display()
editor.undo()
editor.undo()
editor.display()
editor.redo()
editor.display()
