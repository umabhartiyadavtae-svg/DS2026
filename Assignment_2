def linear_search(arr, target):
    for i in arr:
        if i == target:
            return True
    return False

def binary_search(arr, target):
    low = 0
    high = len(arr) - 1
    while low <= high:
        mid = (low + high) // 2
        if arr[mid] == target:
            return True
        elif target < arr[mid]:
            high = mid - 1
        else:
            low = mid + 1
    return False

# Sample usage
customer_ids = [101, 202, 303, 404, 505, 606]
search_id = 303

print("Linear Search Result:", "Found" if linear_search(customer_ids, search_id) else "Not Found")

# Ensure list is sorted before binary search
sorted_ids = sorted(customer_ids)
print("Binary Search Result:", "Found" if binary_search(sorted_ids, search_id) else "Not Found")
